outcome ReasoningConfig {
    action: string
    effort: string
}

strategy reasoning_mode returns ReasoningConfig {
    when {
        reasoning.config == "off"
    } then ReasoningOff {
        action: "set",
        effort: "none",
    }

    when {
        reasoning.config == "low"
        and model.supports_reasoning
    } then ReasoningLow {
        action: "set",
        effort: "low",
    }

    when {
        reasoning.config == "medium"
        and model.supports_reasoning
    } then ReasoningMedium {
        action: "set",
        effort: "medium",
    }

    when {
        reasoning.config == "high"
        and model.supports_reasoning
    } then ReasoningHigh {
        action: "set",
        effort: "high",
    }

    when {
        reasoning.config == "xhigh"
        and model.supports_reasoning
    } then ReasoningXHigh {
        action: "set",
        effort: "xhigh",
    }

    when {
        task.phase == "planning"
        and model.supports_reasoning
    } then PlanningReasoning {
        action: "set",
        effort: "high",
    }

    when {
        task.phase == "review"
        and model.supports_reasoning
    } then ReviewReasoning {
        action: "set",
        effort: "high",
    }

    else ReasoningDefault {
        action: "set",
        effort: "none",
    }
}
